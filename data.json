  "verbs": [],
  "grammar": [
    {
      "title": "Ordinea cuvintelor",
      "text": "În propoziția simplă: Subiect + Verb + Rest. Verbul este foarte des pe poziția a doua.",
      "example_sv": "Jag dricker vatten.",
      "example_ro": "Eu beau apă."
    },
    {
      "title": "Întrebări",
      "text": "La întrebările cu da/nu, verbul vine înaintea subiectului.",
      "example_sv": "Dricker du vatten?",
      "example_ro": "Bei apă?"
    },
    {
      "title": "Negația",
      "text": "Inte înseamnă „nu” și vine de obicei după verb.",
      "example_sv": "Jag förstår inte.",
      "example_ro": "Nu înțeleg."
    },
    {
      "title": "Substantive: en / ett",
      "text": "Învață substantivul împreună cu articolul.",
      "example_sv": "en bil / ett hus",
      "example_ro": "o mașină / o casă"
    },
    {
      "title": "Plural",
      "text": "Pluralul poate avea -or, -ar, -er, -n sau poate rămâne neschimbat.",
      "example_sv": "en bil → bilar",
      "example_ro": "o mașină → mașini"
    },
    {
      "title": "Verbe",
      "text": "La prezent, forma este aceeași pentru toate persoanele.",
      "example_sv": "jag går / du går / vi går",
      "example_ro": "eu merg / tu mergi / noi mergem"
    },
    {
      "title": "Perfect",
      "text": "Perfectul se formează cu har + supin.",
      "example_sv": "Jag har ätit.",
      "example_ro": "Am mâncat."
    },
    {
      "title": "Pronunție",
      "text": "å seamănă cu „o”, ä cu un „e” deschis, iar ö cu un sunet rotunjit.",
      "example_sv": "gå, läsa, fönster",
      "example_ro": "goo, leasa, fênster"
    }
  ]
}